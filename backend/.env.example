DJANGO_ENV=prod
DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_ALLOWED_HOSTS=your-domain.com,api.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Cache
REDIS_URL=redis://127.0.0.1:6379/1
GRAPH_CACHE_TTL_SECONDS=120
ANALYTICS_CACHE_TTL_SECONDS=120

# PostgreSQL (use DATABASE_URL or explicit fields)
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/smart_navigation
# POSTGRES_DB=smart_navigation
# POSTGRES_USER=smart_navigation
# POSTGRES_PASSWORD=replace-with-password
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432

# Monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Security (set to False only in local non-HTTPS environments)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Throttle tuning
THROTTLE_ANON_RATE=60/min
THROTTLE_USER_RATE=300/min
THROTTLE_NAVIGATION_SESSION_RATE=120/min
THROTTLE_ANALYTICS_RATE=60/min
THROTTLE_ANALYTICS_EXPORT_RATE=10/min
